# ======================================================
# BDGW VaultFlow — Environment Configuration
# ======================================================
# Copy this file to .env and fill in your values.
# Lines marked REQUIRED must be filled before first boot.
# Lines marked SETCONFIG can be configured later via the
# /setconfig owner command. Everything else has a default.
# ======================================================

# ======================================================
# REQUIRED — CLIENT MUST FILL THESE FOUR
# ======================================================
API_ID=                     # Telegram API ID — from https://my.telegram.org
API_HASH=                   # Telegram API Hash — from https://my.telegram.org
BOT_TOKEN=                  # Bot token from @BotFather (format: 123456789:AAH...)
ADMIN_IDS=[123456789]       # JSON list of admin Telegram user IDs e.g. [111222,333444]

# ======================================================
# REQUIRED — Platform owner (single user with full control)
# ======================================================
OWNER_ID=123456789

# ======================================================
# REQUIRED — MongoDB
# ======================================================
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=bdgw_vaultflow
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=5

# ======================================================
# REQUIRED — Redis (distributed locks, FSM, caching)
# ======================================================
REDIS_URL=redis://localhost:6379/0

# ======================================================
# REQUIRED — Telegram Chat IDs (numeric, negative for groups/channels)
# ======================================================
VERIFICATION_GROUP_ID=-1001895403473
VAULT_CHANNEL_ID=-1002048690257
NSFW_VAULT_CHANNEL_ID=-1002048690257
PREMIUM_VAULT_CHANNEL_ID=-1003758437237
NSFW_GROUP_ID=-1002908207184
PREMIUM_GROUP_ID=-1002505469098
MAIN_CHANNEL_ID=-1002255449546
LOG_CHANNEL_ID=-1002231418857

# Hub topic IDs — auto-created by bot on first boot if set to 0
HUB_TOPIC_ADMIN_LOGS=0
HUB_TOPIC_AUDIT=0
HUB_SUPERGROUP_ID=0

# ======================================================
# Bot identity
# ======================================================
BOT_USERNAME=BDGWContentBot
SESSION_NAME=vaultflow_bot
SESSION_DIR=./sessions
MAX_CONCURRENT_TRANSMISSIONS=10

# ======================================================
# Destination display names
# ======================================================
NSFW_DISPLAY_NAME=BD GONE WILD
PREMIUM_DISPLAY_NAME=BD GONE WILD PREMIUM

# ======================================================
# Legacy role lists (not used in logic, kept for compat)
# ======================================================
SUDO_IDS=[0]
MODERATOR_IDS=[0]
SUPPORT_ADMIN_IDS=[0]
PAYMENT_ADMIN_IDS=[0]
SCHEDULER_ADMIN_IDS=[0]

# ======================================================
# Worker pools
# ======================================================
DISPATCHER_WORKER_COUNT=4
WATERMARK_WORKER_COUNT=2
WORKER_BATCH_SIZE=5
WORKER_POLL_INTERVAL=2.0

# ======================================================
# Scheduler and fairness
# ======================================================
SCHEDULER_INTERVAL_SECONDS=60
MAX_JOBS_PER_CYCLE=100
RANDOMIZE_POSTING_WINDOW=300
REPOST_PREVENTION_HOURS=168

# ======================================================
# Queue
# ======================================================
QUEUE_DEADLINE_HOURS=24
QUEUE_COLLECTION=queue
DEAD_LETTER_COLLECTION=dead_letters
PENDING_COLLECTION=pending_submissions
SCHEDULER_JOBS_COLLECTION=scheduler_jobs
QUARANTINE_COLLECTION=quarantine
LOCK_COLLECTION=locks
VAULT_COLLECTION=vault
CHANNEL_CONFIG_COLLECTION=channel_config
METRICS_COLLECTION=metrics

# ======================================================
# Daily distribution caps
# ======================================================
DAILY_CAP_NSFW=50
DAILY_CAP_PREMIUM=10
FREE_DAILY_SUBMISSION_LIMIT=5
PREMIUM_DAILY_SUBMISSION_LIMIT=20

# ======================================================
# Retries and backoff
# ======================================================
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY=5.0
RETRY_MAX_DELAY=3600.0
RETRY_JITTER_RANGE=2.0

# ======================================================
# Distributed locks
# ======================================================
LOCK_TTL_SECONDS=300
LOCK_RETRY_ATTEMPTS=5
LOCK_RETRY_DELAY=1.0
STALE_LOCK_THRESHOLD_SECONDS=600

# ======================================================
# Rate limits and FloodWait protection
# ======================================================
GLOBAL_RATE_LIMIT_PER_MIN=30
PER_TARGET_RATE_LIMIT_PER_MIN=10
FLOODWAIT_EXTRA_BUFFER=2
FLOODWAIT_MAX_WAIT=86400
FLOOD_MAX_REQUESTS=5
FLOOD_WINDOW_SECONDS=60

# ======================================================
# Album (media group) handling
# ======================================================
MEDIA_GROUP_TIMEOUT_SECONDS=3.0
MEDIA_GROUP_TIMEOUT=3.0
MEDIA_GROUP_MAX_SIZE=10

# ======================================================
# Media processing directories
# ======================================================
PROCESSED_MEDIA_DIR=./processed
WATERMARK_CACHE_DIR=./watermark_cache
FFMPEG_TIMEOUT=120.0

# ======================================================
# Watermark — WATERMARK_OPACITY must be 0.0 to 1.0
# Spec section 13: photos ~0.35, videos ~0.47
# Default 0.42 approximates the intended 107/255 level
# ======================================================
WATERMARK_ENABLED=true
WATERMARK_LOGO_PATH=./assets/watermarks/nsfw_logo.png
WATERMARK_LOGO_PATH_NSFW=./assets/watermarks/nsfw_logo.png
WATERMARK_LOGO_PATH_PREMIUM=./assets/watermarks/premium_logo.png
WATERMARK_FONT_PATH=./assets/fonts/Montserrat-SemiBold.ttf
WATERMARK_TEXT_NSFW=BD GONE WILD
WATERMARK_TEXT_PREMIUM=BD GONE WILD PREMIUM
WATERMARK_POSITION=BOTTOM_RIGHT
WATERMARK_ROTATION=-27
WATERMARK_OPACITY=0.42
WATERMARK_SCALE=0.040

# ======================================================
# Vault
# ======================================================
VAULT_IMMUTABLE=true

# ======================================================
# Subscriptions and invites
# ======================================================
GRACE_PERIOD_DAYS=3
INVITE_EXPIRY_MINUTES=30

# ======================================================
# Runtime and logging
# ======================================================
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=JSON
