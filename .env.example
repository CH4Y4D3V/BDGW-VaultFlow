# ══════════════════════════════════════════════════════════════════
# BDGW VaultFlow — Environment Configuration Template
# Copy to .env and fill in all required values before running.
# Lines marked REQUIRED must be set. Others have safe defaults.
# ══════════════════════════════════════════════════════════════════

# ── Pyrogram (REQUIRED) ───────────────────────────────────────────
# Get API_ID and API_HASH from https://my.telegram.org
API_ID=
API_HASH=
BOT_TOKEN=
# Your bot's Telegram username (without @). Used for referral deep links.
BOT_USERNAME=

SESSION_NAME=vaultflow_bot
SESSION_DIR=./sessions
MAX_CONCURRENT_TRANSMISSIONS=10

# ── MongoDB (REQUIRED) ────────────────────────────────────────────
MONGO_URI=
MONGO_DB_NAME=bdgw_vaultflow
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=5

# Collection names (change only if you need custom names)
QUEUE_COLLECTION=queue
DEAD_LETTER_COLLECTION=dead_letters
LOCK_COLLECTION=locks
METRICS_COLLECTION=metrics
VAULT_COLLECTION=vault
CHANNEL_CONFIG_COLLECTION=channel_config
PENDING_COLLECTION=pending_submissions
SCHEDULER_JOBS_COLLECTION=scheduler_jobs
QUARANTINE_COLLECTION=quarantine

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=

# ── Telegram Channel / Group IDs (REQUIRED) ───────────────────────
# The supergroup where moderators review submissions (must have Topics enabled)
VERIFICATION_GROUP_ID=

# The channel where approved content is archived permanently
VAULT_CHANNEL_ID=

# Distribution destination groups (set at least one)
NSFW_GROUP_ID=0
PREMIUM_GROUP_ID=0

# Optional: channel used for premium invite link generation
PREMIUM_CHANNEL_ID=0

# Optional: structured log channel for takedown alerts
LOG_CHANNEL_ID=0

# ── Destination Display Names ─────────────────────────────────────
NSFW_DISPLAY_NAME=BD GONE WILD
PREMIUM_DISPLAY_NAME=BD GONE WILD ✦ PREMIUM

# ── Access Control (REQUIRED) ─────────────────────────────────────────
# Only OWNER_ID and ADMIN_IDS are used. All admins have full access.
# There are no granular sub-roles — owner and admins are equivalent.
OWNER_ID=

# JSON array of Telegram user IDs that have full admin access   
ADMIN_IDS=[]
SUDO_IDS=[]
MODERATOR_IDS=[]
SUPPORT_ADMIN_IDS=[]
PAYMENT_ADMIN_IDS=[]

# ── Verification Hub Topics ───────────────────────────────────────────
HUB_TOPIC_PAYMENTS=0
HUB_TOPIC_CONTENT_REVIEW=0
HUB_TOPIC_SUPPORT=0
HUB_TOPIC_TAKEDOWN=0
HUB_TOPIC_USER_MOD=0
HUB_TOPIC_BROADCASTS=0
HUB_TOPIC_AUDIT=0

# ── Worker Pools ──────────────────────────────────────────────────
DISPATCHER_WORKER_COUNT=4
WATERMARK_WORKER_COUNT=2
WORKER_BATCH_SIZE=5
WORKER_POLL_INTERVAL=2.0

# ── Scheduler & Fairness ──────────────────────────────────────────
SCHEDULER_INTERVAL_SECONDS=60
MAX_JOBS_PER_CYCLE=100
RANDOMIZE_POSTING_WINDOW=300
REPOST_PREVENTION_HOURS=168

# ── Queue ─────────────────────────────────────────────────────────
QUEUE_DEADLINE_HOURS=24

# ── Retries & Backoff ─────────────────────────────────────────────
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY=5.0
RETRY_MAX_DELAY=3600.0
RETRY_JITTER_RANGE=2.0

# ── Distributed Locks ─────────────────────────────────────────────
LOCK_TTL_SECONDS=300
LOCK_RETRY_ATTEMPTS=5
LOCK_RETRY_DELAY=1.0
STALE_LOCK_THRESHOLD_SECONDS=600

# ── Rate Limits & Flood Protection ────────────────────────────────
GLOBAL_RATE_LIMIT_PER_MIN=30
PER_TARGET_RATE_LIMIT_PER_MIN=10
FLOODWAIT_EXTRA_BUFFER=2
FLOODWAIT_MAX_WAIT=86400

# ── Media Groups ──────────────────────────────────────────────────
MEDIA_GROUP_TIMEOUT_SECONDS=3.0
MEDIA_GROUP_MAX_SIZE=10

# ── Media Processing ──────────────────────────────────────────────
PROCESSED_MEDIA_DIR=./processed
WATERMARK_CACHE_DIR=./watermark_cache
FFMPEG_TIMEOUT=120.0

# ── Watermark Assets ──────────────────────────────────────────────
WATERMARK_ENABLED=false

WATERMARK_LOGO_PATH_NSFW=./assets/watermarks/nsfw_logo.png
WATERMARK_LOGO_PATH_PREMIUM=./assets/watermarks/premium_logo.png
WATERMARK_LOGO_PATH=./assets/watermarks/nsfw_logo.png

WATERMARK_TEXT_NSFW=𝐁𝐃 𝐆𝐎𝐍𝐄 𝐖𝐈𝐋𝐃 𝐕𝐈𝐃𝐄𝐎
WATERMARK_TEXT_PREMIUM=𝐁𝐃 𝐆𝐎𝐍𝐄 𝐖𝐈𝐋𝐃 ✦ 𝐏𝐑𝐄𝐌𝐈𝐔𝐌

# Accepted values: BOTTOM_RIGHT, BOTTOM_LEFT, TOP_RIGHT, TOP_LEFT, CENTER
WATERMARK_POSITION=BOTTOM_RIGHT
WATERMARK_OPACITY=0.8
WATERMARK_SCALE=0.15

# ── Vault ─────────────────────────────────────────────────────────
VAULT_IMMUTABLE=true

# ── Subscriptions ─────────────────────────────────────────────────
GRACE_PERIOD_DAYS=3

# ── Invite Security ───────────────────────────────────────────────
# How long invite links remain valid (minutes). 30 is the secure default.
INVITE_EXPIRY_MINUTES=30

# ── Daily Distribution Caps ───────────────────────────────────────
DAILY_CAP_NSFW=75
DAILY_CAP_PREMIUM=140

# ── Runtime ───────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=JSON