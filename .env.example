# .env.example
# -----------------------------------------------------------------------------
# Copy this file to .env and fill in the values.
# Do NOT commit the .env file to version control.
# -----------------------------------------------------------------------------

# ─── Core Bot Settings ───────────────────────────────────────────────────────
BOT_TOKEN=""
API_ID=""
API_HASH=""

# ─── Database & Cache ────────────────────────────────────────────────────────
MONGO_URI="mongodb://localhost:27017"
MONGO_DB_NAME="vault_flow_db"
REDIS_URL="redis://localhost:6379/0"
REDIS_MAX_CONNECTIONS=20

# ─── Telegram Channel/Group IDs ──────────────────────────────────────────────
VERIFICATION_GROUP_ID=""  # Hub for moderation, support, admin logs
VAULT_CHANNEL_ID=""       # Private channel where all content is archived
NSFW_GROUP_ID=""          # Public-facing NSFW distribution channel
PREMIUM_GROUP_ID=""       # Public-facing SFW/Premium distribution channel
PREMIUM_CHANNEL_ID=""     # Optional: if premium content also goes to a channel

# ─── User Roles ──────────────────────────────────────────────────────────────
# Comma-separated list of integer user IDs
ADMIN_IDS=""
MOD_IDS=""

# ─── Distribution & Queue Settings ───────────────────────────────────────────
DISTRIBUTION_INTERVAL_SECONDS=30
MAX_CONCURRENT_JOBS=10
MAX_RETRY_ATTEMPTS=3
QUEUE_DEADLINE_HOURS=72
JOB_LOCK_TTL_SECONDS=300
VAULT_FILL_COOLDOWN_HOURS=24

# ─── Watermark Settings (NEW-10) ─────────────────────────────────────────────
WATERMARK_ENABLED=true
WATERMARK_LOGO_PATH_NSFW="assets/watermarks/logo_nsfw.png"
WATERMARK_LOGO_PATH_PREMIUM="assets/watermarks/logo_premium.png"
WATERMARK_TEXT_NSFW="Your Brand"
WATERMARK_TEXT_PREMIUM="Your Brand Premium"
WATERMARK_POSITION="BOTTOM_RIGHT" # Options: TOP_LEFT, TOP_RIGHT, BOTTOM_LEFT, BOTTOM_RIGHT, CENTER
WATERMARK_OPACITY=0.8
WATERMARK_SCALE=0.15
WATERMARK_ROTATION=0
WATERMARK_POLL_INTERVAL=10 # Seconds

# ─── Anti-Spam & Rate Limiting (NEW-05) ──────────────────────────────────────
SPAM_WINDOW_SECONDS=5
SPAM_MAX_MESSAGES=5
STRIKE_LIMIT_FOR_MUTE=3
STRIKE_LIMIT_FOR_BAN=5
MUTE_DURATION_MINUTES=30
FLOODWAIT_EXTRA_BUFFER=2

# ─── Timers & Timeouts ───────────────────────────────────────────────────────
ALBUM_COLLECTION_SECONDS=2.0
PAYMENT_SESSION_TIMEOUT_MINUTES=20
PAYMENT_WARNING_MINUTES=5

# ─── Membership Reconciliation (NEW-11) ──────────────────────────────────────
RECONCILIATION_INTERVAL_HOURS=6
